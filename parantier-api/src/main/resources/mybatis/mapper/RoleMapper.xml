<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mapo.palantier.role.infrastructure.RoleMapper">

    <resultMap id="RoleResultMap" type="com.mapo.palantier.role.domain.Role">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 모든 역할 조회 -->
    <select id="findAll" resultMap="RoleResultMap">
        SELECT id, name, description, created_at
        FROM role
        ORDER BY created_at DESC
    </select>

    <!-- ID로 역할 조회 -->
    <select id="findById" resultMap="RoleResultMap">
        SELECT id, name, description, created_at
        FROM role
        WHERE id = #{id}
    </select>

    <!-- 이름으로 역할 조회 -->
    <select id="findByName" resultMap="RoleResultMap">
        SELECT id, name, description, created_at
        FROM role
        WHERE name = #{name}
    </select>

    <!-- 역할 생성 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO role (name, description)
        VALUES (#{name}, #{description})
    </insert>

    <!-- 역할 수정 -->
    <update id="update">
        UPDATE role
        SET name = #{name},
            description = #{description}
        WHERE id = #{id}
    </update>

    <!-- 역할 삭제 -->
    <delete id="deleteById">
        DELETE FROM role WHERE id = #{id}
    </delete>

    <!-- 역할이 가진 권한 ID 목록 조회 -->
    <select id="findAuthorityIdsByRoleId" resultType="java.lang.Long">
        SELECT authority_id
        FROM role_authority
        WHERE role_id = #{roleId}
        ORDER BY authority_id
    </select>

    <!-- 역할에 권한 추가 -->
    <insert id="insertRoleAuthority">
        INSERT INTO role_authority (role_id, authority_id)
        VALUES (#{roleId}, #{authorityId})
        ON CONFLICT (role_id, authority_id) DO NOTHING
    </insert>

    <!-- 역할에서 권한 제거 -->
    <delete id="deleteRoleAuthority">
        DELETE FROM role_authority
        WHERE role_id = #{roleId} AND authority_id = #{authorityId}
    </delete>

    <!-- 역할의 모든 권한 제거 -->
    <delete id="deleteAllRoleAuthorities">
        DELETE FROM role_authority WHERE role_id = #{roleId}
    </delete>

</mapper>
